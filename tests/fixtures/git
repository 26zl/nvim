#!/usr/bin/env sh
set -eu

log_operation() {
  if [ -n "${FAKE_GIT_LOG:-}" ]; then
    printf '%s\n' "$1" >>"$FAKE_GIT_LOG"
  fi
}

fail_if_requested() {
  if [ "${FAKE_GIT_FAIL_OPERATION:-}" = "$1" ]; then
    printf '%s\n' "simulated git $1 failure" >&2
    exit 42
  fi
}

if [ "$1" = "-C" ]; then
  shift 2
  operation=$1
  case "$operation" in
    remote)
      printf '%s\n' "${FAKE_GIT_ORIGIN:-https://github.com/26zl/nvim}"
      ;;
    ls-files)
      ;;
    pull | fetch | merge | checkout)
      log_operation "$operation"
      fail_if_requested "$operation"
      ;;
    rev-parse)
      printf '%s\n' "${FAKE_GIT_HEAD:-0000000000000000000000000000000000000000}"
      ;;
    *)
      printf 'unsupported fake git operation: %s\n' "$operation" >&2
      exit 2
      ;;
  esac
  exit 0
fi

if [ "$1" = "clone" ]; then
  log_operation clone
  fail_if_requested clone
  destination=
  for argument in "$@"; do
    destination=$argument
  done
  parent=${destination%/*}
  if [ "${FAKE_GIT_REQUIRE_PARENT:-0}" = "1" ] && [ ! -d "$parent" ]; then
    exit 42
  fi
  mkdir -p "$destination/.git"
  exit 0
fi

printf 'unsupported fake git invocation: %s\n' "$*" >&2
exit 2
